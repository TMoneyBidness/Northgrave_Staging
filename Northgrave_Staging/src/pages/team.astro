---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Team from "../components/sections/Team.astro";

import teamData from "../../content/team.json";
---

<BaseLayout
  title="The Team — Northgrave Pictures"
  description="Meet the team behind Northgrave Pictures — Cheryl Meyer and Justin Harding."
>
  <Header transparent={false} />

  <main>
    <div class="team-page__spacer"></div>
    <Team
      heading={teamData.heading}
      intro={teamData.intro}
      members={teamData.members}
    />
  </main>

  <Footer />
</BaseLayout>

<style>
  .team-page__spacer {
    height: 5rem;
    background: var(--color-night-deep);
  }
</style>
